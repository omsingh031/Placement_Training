{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "compile and run",
            "type": "process",
            "command": "cmd.exe",
            "args": [
                "/c",
                "g++",
                "-std=c++17",
                "${file}",
                "-o",
                "${fileBasenameNoExtension}.exe",
                "&&",
                "${fileBasenameNoExtension}.exe",
                "<",
                "input.txt",
                ">",
                "output.txt"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared",
                "clear": true
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}